# Secrets für docker-compose.yml (Datei als ".env" ins Repo-Root legen, nie committen)

# Erzeugen mit: npm run hash-password --workspace server -- <dein-passwort>
MASTER_PASSWORD_HASH=

# Mindestens 32 Zeichen. Erzeugen mit: openssl rand -hex 32
SESSION_SECRET=

# Domain für Caddy (automatisches Let's Encrypt-Zertifikat)
DOMAIN=medi-journal.example.com
